# App
APP_ENV=development
SECRET_KEY=dev-secret-change-me
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/auram
REDIS_URL=redis://localhost:6379/0

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=auram_chunks

# Live audio provider: livekit (self-hosted agent) or vapi
AUDIO_PROVIDER=livekit

# LiveKit (use devkey/secret with the local dev server)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_WS_URL=ws://localhost:7880

# VAPI (used when AUDIO_PROVIDER=vapi; create the assistant on the dashboard)
# Use the PUBLIC key (sent to the browser), not the private key.
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# Realtime host agent (GA model; or gpt-4o-realtime-preview)
REALTIME_MODEL=gpt-realtime
REALTIME_VOICE=alloy

# AI providers
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=
DEFAULT_TTS_PROVIDER=openai
DEFAULT_STT_PROVIDER=openai

# Models
SCRIPT_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
TTS_MODEL=gpt-4o-mini-tts

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Storage
AUDIO_STORAGE_DIR=./storage/audio
